<!DOCTYPE html>
<html>
<head>
  <title>Login - Faturé Store</title>
  <!-- Panggil Font Awesome untuk Ikon -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #1e3c72, #2a5298);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      position: relative;
    }

    /* Dekorasi Lingkaran di Background */
    .circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
    }
    .circle-1 { width: 300px; height: 300px; top: -50px; left: -50px; }
    .circle-2 { width: 150px; height: 150px; bottom: 50px; right: -30px; }
    .circle-3 { width: 80px; height: 80px; top: 40%; left: 20%; }

    .card {
      background: white;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.3);
      width: 380px;
      text-align: center;
      z-index: 10;
    }

    .logo {
      margin: 0 0 5px 0;
      color: #1e3c72;
      font-size: 32px;
      font-weight: 800;
      letter-spacing: 4px; /* Huruf renggang seperti di gambar */
    }

    .subtitle {
      color: #777;
      margin-bottom: 30px;
      font-size: 14px;
    }

    .form-group {
      margin-bottom: 20px;
      position: relative;
      text-align: left;
    }

    /* Ikon di dalam input */
    .form-group .icon {
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      font-size: 16px;
    }

    .form-group input {
      width: 100%;
      padding: 15px 15px 15px 45px; /* Padding kiri 45px untuk ruang ikon */
      border: 1px solid #ddd;
      border-radius: 12px;
      box-sizing: border-box;
      font-size: 14px;
      color: #333;
      transition: 0.3s;
    }

    .form-group input::placeholder {
      color: #bbb;
    }

    .form-group input:focus {
      border-color: #FFC107;
      outline: none;
      box-shadow: 0 0 10px rgba(255, 193, 7, 0.25);
    }

    .btn-login {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #FFD700, #FFC107); /* Tombol Kuning */
      color: #1e3c72;
      border: none;
      border-radius: 12px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      letter-spacing: 1px;
      margin-top: 10px;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(255, 193, 7, 0.4);
    }

    .auth-link {
      margin-top: 25px;
      font-size: 14px;
      color: #666;
    }

    .auth-link a {
      color: #2a5298;
      text-decoration: none;
      font-weight: bold;
    }

    .auth-link a:hover {
      text-decoration: underline;
    }

    /* Notifikasi */
    .alert {
      padding: 12px;
      margin-bottom: 20px;
      border-radius: 10px;
      font-size: 13px;
      text-align: center;
    }
    .alert-error {
      background: #ffe6e6;
      color: #d63031;
      border: 1px solid #fab1a0;
    }
    .alert-success {
      background: #e6ffe6;
      color: #27ae60;
      border: 1px solid #a0e6a0;
    }
  </style>
</head>
<body>

  <!-- Dekorasi Lingkaran Background -->
  <div class="circle circle-1"></div>
  <div class="circle circle-2"></div>
  <div class="circle circle-3"></div>

  <div class="card">
    <h2 class="logo">FATURÉ</h2>
    <p class="subtitle">Masuk ke akun Anda</p>

    <!-- Notifikasi Error & Success -->
    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <!-- Form Login -->
    <form action="/login" method="POST">
      <div class="form-group">
        <i class="fas fa-user icon"></i>
        <input type="text" name="username" placeholder="Masukkan username" required>
      </div>
      
      <div class="form-group">
        <i class="fas fa-lock icon"></i>
        <input type="password" name="password" placeholder="Masukkan password" required>
      </div>

      <button type="submit" class="btn-login">MASUK</button>
    </form>

    <div class="auth-link">
      Belum punya akun? <a href="/register">Daftar di sini</a>
    </div>
  </div>

</body>
</html>