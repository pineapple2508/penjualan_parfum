<%- include('partials/header', { title: 'Katalog Produk' }) %>

<section class="catalog-section">
  <div class="container">
    <h2 class="section-title">Koleksi Parfum</h2>
    <p class="section-subtitle">Temukan aroma spesial untuk setiap momen Anda</p>
    
    <div class="product-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="product-card">
            <div class="product-image-wrapper">
              <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
            </div>
            
            <div class="card-body">
              <h3><%= product.name %></h3>
              <p class="price">Rp <%= product.price.toLocaleString('id-ID') %></p>
              <p class="description"><%= product.description ? product.description.substring(0, 80) + '...' : 'Parfum premium dengan aroma memukau.' %></p>
              
              <div class="btn-group">
                <% if (user) { %>
                  <a href="/orders/add/<%= product._id %>" class="btn-buy">Beli Sekarang</a>
                  <form action="/cart/add" method="POST" class="form-cart">
                    <input type="hidden" name="product_id" value="<%= product._id %>">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn-cart">🛒</button>
                  </form>
                <% } else { %>
                  <a href="/login" class="btn-buy" style="width: 100%;">Login untuk Beli</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="empty-state">Belum ada produk saat ini.</p>
      <% } %>
    </div>
  </div>
</section>

<style>
  .catalog-section { background: #f8fafc; padding: 60px 0 80px; min-height: 80vh; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .section-title { font-size: 2.2rem; color: #1e3c72; font-family: 'Playfair Display', serif; text-align: center; margin-bottom: 8px; }
  .section-subtitle { text-align: center; color: #64748b; font-size: 1rem; margin-bottom: 35px; }

  .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 20px; }
  .product-card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: transform 0.3s, box-shadow 0.3s; border: 1px solid #e2e8f0; display: flex; flex-direction: column; }
  .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(30, 60, 114, 0.15); }

  .product-image-wrapper { width: 100%; height: 200px; overflow: hidden; position: relative; }
  .product-image { width: 100%; height: 100%; object-fit: cover; border-bottom: 2px solid #FFD700; transition: transform 0.5s ease; }
  .product-card:hover .product-image { transform: scale(1.05); }

  .card-body { padding: 15px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; }
  .card-body h3 { font-family: 'Playfair Display', serif; margin: 0 0 5px 0; color: #0f1c36; font-size: 1.1rem; }
  .price { font-size: 1.1rem; font-weight: 800; color: #1e3c72; margin: 0 0 8px; }
  .description { font-size: 0.8rem; color: #64748b; line-height: 1.5; margin-bottom: 15px; flex-grow: 1; height: 40px; overflow: hidden; }
  
  .btn-group { display: flex; gap: 8px; justify-content: center; margin-top: auto; }
  .btn-buy { display: block; flex: 1; background: #FFD700; color: #0f1c36; padding: 8px; text-decoration: none; border-radius: 6px; font-weight: 700; font-size: 0.8rem; text-align: center; transition: 0.3s; border: 2px solid #FFD700; }
  .btn-buy:hover { background: transparent; color: #FFD700; }
  .form-cart { margin: 0; width: auto; flex: 0 0 auto; }
  .btn-cart { width: 100%; background: white; color: #0f1c36; border: 2px solid #0f1c36; padding: 8px 12px; border-radius: 6px; font-size: 0.9rem; cursor: pointer; transition: 0.3s; }
  .btn-cart:hover { background: #0f1c36; color: #FFD700; }
  .empty-state { text-align: center; color: #94a3b8; grid-column: 1/-1; padding: 60px 0; font-size: 1.2rem; }

  @media (max-width: 768px) { 
    .section-title { font-size: 1.8rem; } 
    .section-subtitle { font-size: 0.9rem; } 
    .product-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; } 
    .product-image-wrapper { height: 160px; }
    .card-body { padding: 12px; }
    .card-body h3 { font-size: 1rem; }
    .price { font-size: 1rem; }
    .description { font-size: 0.75rem; height: 35px; }
    .btn-buy { padding: 6px; font-size: 0.75rem; }
    .btn-cart { padding: 6px 10px; font-size: 0.8rem; }
  }
</style>

<%- include('partials/footer') %>