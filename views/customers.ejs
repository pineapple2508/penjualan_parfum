<%- include('partials/header', { title: 'Data Customer' }) %>

<div class="admin-container">
  <div class="page-header">
    <div>
      <h2>Data Customer</h2>
      <p class="subtitle">Data pelanggan terdaftar secara otomatis dari pesanan yang masuk</p>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Kontak</th>
            <th>Alamat</th>
            <!-- Kolom Aksi sudah dihapus -->
          </tr>
        </thead>
        <tbody>
          <% if (data.length > 0) { %>
            <% data.forEach(item => { %>
            <tr>
              <td>
                <div class="customer-info">
                  <div class="avatar"><%= item.name.charAt(0).toUpperCase() %></div>
                  <div>
                    <div class="name"><%= item.name %></div>
                    <div class="id-text">ID: <%= item._id.toString().substring(0, 8) %>...</div>
                  </div>
                </div>
              </td>
              <td>
                <div class="contact-info">
                  <div><i class="fas fa-envelope"></i> <%= item.email %></div>
                  <div><i class="fas fa-phone"></i> <%= item.phone || '-' %></div>
                </div>
              </td>
              <td><i class="fas fa-map-marker-alt" style="color: #94a3b8; margin-right: 5px;"></i> <%= item.address || '-' %></td>
              <!-- Kolom Aksi sudah dihapus -->
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="3" class="empty-state"> <!-- Colspan diubah jadi 3 -->
                <i class="fas fa-users"></i>
                <p>Belum ada data customer</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .admin-container { max-width: 1100px; margin: 0 auto; padding: 2rem; }
  
  .page-header { margin-bottom: 2rem; }
  .page-header h2 { margin: 0; color: #1e3c72; font-size: 1.8rem; }
  .subtitle { margin: 5px 0 0; color: #64748b; font-size: 0.9rem; }

  .card {
    background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid #e2e8f0; overflow: hidden;
  }

  .table-responsive { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  
  th {
    background: #f8fafc; padding: 16px 20px; text-align: left; font-weight: 700;
    color: #475569; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
    border-bottom: 2px solid #e2e8f0;
  }
  
  td { padding: 20px; border-bottom: 1px solid #f1f5f9; color: #334155; vertical-align: middle; }
  tr:hover { background: #f8fafc; }
  tr:last-child td { border-bottom: none; }

  .customer-info { display: flex; align-items: center; gap: 15px; }
  .avatar {
    width: 45px; height: 45px; background: linear-gradient(135deg, #1e3c72, #2a5298);
    color: #FFD700; border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 1.2rem; box-shadow: 0 4px 6px rgba(30, 60, 114, 0.2);
  }
  .name { font-weight: 600; color: #1e293b; font-size: 1rem; }
  .id-text { font-size: 0.75rem; color: #94a3b8; margin-top: 2px; }

  .contact-info div { margin-bottom: 5px; font-size: 0.9rem; color: #475569; }
  .contact-info i { width: 20px; color: #94a3b8; font-size: 0.8rem; text-align: center; }

  .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
  .empty-state i { font-size: 3rem; margin-bottom: 15px; display: block; }
</style>

<%- include('partials/footer') %>