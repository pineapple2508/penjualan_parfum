<%- include('partials/header', { title: 'Buat Pesanan' }) %>

<div class="container">
  <div class="header">
    <h2>Formulir Pemesanan</h2>
    <a href="/products" class="btn-back">← Kembali</a>
  </div>

  <div class="form-card">
    <div class="product-summary">
      <h3><%= product.name %></h3>
      <p>Harga: Rp <%= product.price.toLocaleString('id-ID') %> / pcs</p>
    </div>

    <form action="/orders/save" method="POST">
      <input type="hidden" name="product_id" value="<%= product._id %>">
      
      <div class="section-title">Data Diri Pemesan</div>
      <div class="form-group">
        <label>Nama Lengkap</label>
        <div class="input-icon"><i class="fas fa-user"></i><input type="text" name="customer_name" placeholder="Masukkan nama lengkap" required></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Email</label>
          <div class="input-icon"><i class="fas fa-envelope"></i><input type="email" name="customer_email" placeholder="email@contoh.com" required></div>
        </div>
        <div class="form-group">
          <label>No. Telepon</label>
          <div class="input-icon"><i class="fas fa-phone"></i><input type="tel" name="customer_phone" placeholder="08xxxxxxxxxx" required></div>
        </div>
      </div>
      <div class="form-group">
        <label>Alamat Pengiriman</label>
        <div class="input-icon"><i class="fas fa-map-marker-alt"></i><textarea name="customer_address" rows="2" placeholder="Masukkan alamat lengkap" required></textarea></div>
      </div>

      <div class="section-title">Pengiriman & Pembayaran</div>
      <div class="form-row">
        <div class="form-group">
          <label>Jasa Pengiriman</label>
          <select name="shipping_service" required>
            <option value="JNE Reguler">JNE Reguler (Rp 20.000)</option>
            <option value="J&T Express">J&T Express (Rp 18.000)</option>
            <option value="SiCepat BEST">SiCepat BEST (Rp 25.000)</option>
          </select>
        </div>
        <div class="form-group">
          <label>Metode Pembayaran</label>
          <select name="payment_method" required>
            <option value="Transfer Bank">Transfer Bank</option>
            <option value="E-Wallet">E-Wallet</option>
            <option value="COD">COD (Bayar di Tempat)</option>
          </select>
        </div>
      </div>

      <div class="section-title">Detail Pesanan</div>
      <div class="form-row">
        <div class="form-group">
          <label>Jumlah Beli</label>
          <div class="input-icon"><i class="fas fa-box"></i><input type="number" name="quantity" min="1" max="<%= product.stock %>" placeholder="Jumlah" required></div>
        </div>
        <div class="form-group">
          <label>Tanggal Pesan</label>
          <div class="input-icon"><i class="fas fa-calendar-alt"></i><input type="date" name="order_date" required></div>
        </div>
      </div>

      <button type="submit" class="btn-submit">🛒 Buat Pesanan</button>
    </form>
  </div>
</div>

<style>
  .container { max-width: 550px; margin: 0 auto; padding: 2rem 1rem; font-family: 'Segoe UI', sans-serif; }
  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  h2 { margin: 0; font-size: 1.4rem; font-weight: 600; color: #1e3c72; }
  h3 { margin: 0 0 5px 0; color: #1e3c72; font-size: 1.1rem; }
  .btn-back { color: #1e3c72; text-decoration: none; font-weight: 600; font-size: 0.9rem; }
  .form-card { background: white; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border: 1px solid #e5e7eb; }
  .product-summary { background: #f0f4ff; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center; border: 1px solid #dbeafe; }
  .product-summary p { margin: 3px 0; color: #4b5563; font-size: 0.85rem; }
  .section-title { font-size: 0.85rem; font-weight: 700; color: #1e3c72; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.8rem; border-bottom: 2px solid #f0f4ff; padding-bottom: 0.4rem; }
  .form-group { margin-bottom: 0.8rem; position: relative; }
  .form-group label { display: block; margin-bottom: 0.3rem; font-weight: 600; color: #333; font-size: 0.8rem; }
  .input-icon { position: relative; }
  .input-icon i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 0.85rem; pointer-events: none; }
  .input-icon input, .input-icon textarea, .form-group select { 
    width: 100%; padding: 0.5rem 0.6rem 0.5rem 2rem; border: 1px solid #cbd5e1; 
    border-radius: 6px; font-size: 0.85rem; box-sizing: border-box; transition: 0.2s; background: #fafafa;
  }
  .form-group select { padding-left: 0.6rem; } /* Select tidak butuh ikon */
  .input-icon textarea { resize: none; }
  .input-icon input:focus, .input-icon textarea:focus, .form-group select:focus { border-color: #FFC107; outline: none; box-shadow: 0 0 0 2px rgba(255, 193, 7, 0.2); background: white; }
  .form-row { display: flex; gap: 1rem; }
  .form-row .form-group { flex: 1; }
  .btn-submit { width: 100%; padding: 0.7rem; background: #FFC107; color: #1e3c72; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: 0.2s; margin-top: 0.5rem; }
  .btn-submit:hover { background: #FFD700; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(255, 193, 7, 0.3); }
  @media (max-width: 600px) { .form-row { flex-direction: column; gap: 0; } }
</style>

<%- include('partials/footer') %>